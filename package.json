{
  "name": "hybrid-form-ai",
  "version": "0.1.5",
  "description": "Hybrid paper + digital form collection powered by multimodal LLMs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.mjs",
      "require": "./dist/providers/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "form",
    "ocr",
    "ai",
    "llm",
    "surveyjs",
    "paper-forms",
    "document-processing",
    "multimodal",
    "openai",
    "anthropic",
    "ollama",
    "qr-code",
    "data-extraction"
  ],
  "author": "SurveyJS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/surveyjs/hybrid-form-ai.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "openai": "^6.0.0",
    "sharp": "^0.33.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "openai": "^6.0.0",
    "sharp": "^0.33.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^2.0.0"
  }
}
